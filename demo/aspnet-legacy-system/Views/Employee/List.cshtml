@model IEnumerable<LegacySystem.Models.Employee>

<!DOCTYPE html>
<html>
<head>
    <title>Employee List</title>
</head>
<body>
    <h1>Employees</h1>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Department</th>
                <th>Attendances</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in Model)
            {
                <tr>
                    <td>@employee.Id</td>
                    <!-- 問題: XSS脆弱性 - Html.Rawの使用 -->
                    <td>@Html.Raw(employee.Name)</td>
                    <td>@employee.Email</td>
                    <td>@employee.Department</td>
                    <!-- 問題: N+1クエリ - Attendancesにアクセス -->
                    <td>@employee.Attendances.Count</td>
                    <td>
                        <a href="/Employee/Delete/@employee.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
