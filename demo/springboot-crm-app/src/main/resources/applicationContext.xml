<?xml version="1.0" encoding="UTF-8"?>
<!-- ISSUE: XMLベースの設定（レガシー） - JavaConfigが推奨される -->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:tx="http://www.springframework.org/schema/tx"
       xmlns:jpa="http://www.springframework.org/schema/data/jpa"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/tx
           http://www.springframework.org/schema/tx/spring-tx.xsd
           http://www.springframework.org/schema/data/jpa
           http://www.springframework.org/schema/data/jpa/spring-jpa.xsd">

    <!-- ISSUE: コンポーネントスキャンが重複（application.propertiesとXML両方で定義） -->
    <context:component-scan base-package="com.example.crm"/>

    <!-- ISSUE: データソース設定がハードコード（環境変数未使用） -->
    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
        <!-- ISSUE: 本番環境のDB認証情報がハードコード -->
        <property name="driverClassName" value="com.mysql.jdbc.Driver"/>
        <property name="url" value="jdbc:mysql://prod-db.internal:3306/crm_production"/>
        <property name="username" value="crm_admin"/>
        <property name="password" value="Pr0d_P@ssw0rd!"/>

        <!-- ISSUE: コネクションプール設定が不適切 -->
        <property name="initialSize" value="100"/>  <!-- ISSUE: 初期サイズが大きすぎ -->
        <property name="maxTotal" value="1000"/>    <!-- ISSUE: 最大接続数が多すぎ -->
        <property name="maxIdle" value="500"/>
        <property name="minIdle" value="100"/>
        <property name="maxWaitMillis" value="60000"/>

        <!-- ISSUE: バリデーションクエリが非効率 -->
        <property name="validationQuery" value="SELECT COUNT(*) FROM customers"/>
        <property name="testOnBorrow" value="true"/>
        <property name="testOnReturn" value="true"/>
        <property name="testWhileIdle" value="true"/>
    </bean>

    <!-- ISSUE: EntityManagerFactory設定 -->
    <bean id="entityManagerFactory"
          class="org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean">
        <property name="dataSource" ref="dataSource"/>
        <property name="packagesToScan" value="com.example.crm.model"/>
        <property name="jpaVendorAdapter">
            <bean class="org.springframework.orm.jpa.vendor.HibernateJpaVendorAdapter">
                <!-- ISSUE: 本番環境でshow_sql=true -->
                <property name="showSql" value="true"/>
                <property name="generateDdl" value="true"/>
                <property name="databasePlatform" value="org.hibernate.dialect.MySQL5Dialect"/>
            </bean>
        </property>
        <property name="jpaProperties">
            <props>
                <!-- ISSUE: 本番でddl-auto=create-drop -->
                <prop key="hibernate.hbm2ddl.auto">create-drop</prop>
                <!-- ISSUE: SQLフォーマット（パフォーマンス低下） -->
                <prop key="hibernate.format_sql">true</prop>
                <!-- ISSUE: 統計情報出力（パフォーマンス低下） -->
                <prop key="hibernate.generate_statistics">true</prop>
                <!-- ISSUE: 二次キャッシュ無効 -->
                <prop key="hibernate.cache.use_second_level_cache">false</prop>
                <prop key="hibernate.cache.use_query_cache">false</prop>
            </props>
        </property>
    </bean>

    <!-- ISSUE: トランザクションマネージャー -->
    <bean id="transactionManager" class="org.springframework.orm.jpa.JpaTransactionManager">
        <property name="entityManagerFactory" ref="entityManagerFactory"/>
        <!-- ISSUE: タイムアウト設定なし -->
    </bean>

    <tx:annotation-driven transaction-manager="transactionManager"/>

    <!-- ISSUE: メール設定がハードコード -->
    <bean id="mailSender" class="org.springframework.mail.javamail.JavaMailSenderImpl">
        <property name="host" value="smtp.company.internal"/>
        <property name="port" value="587"/>
        <property name="username" value="crm-notifications@company.com"/>
        <property name="password" value="M@ilP@ss123!"/>
        <property name="javaMailProperties">
            <props>
                <!-- ISSUE: TLSが無効 -->
                <prop key="mail.smtp.auth">true</prop>
                <prop key="mail.smtp.starttls.enable">false</prop>
                <!-- ISSUE: デバッグ出力が有効 -->
                <prop key="mail.debug">true</prop>
            </props>
        </property>
    </bean>

    <!-- ISSUE: 外部API設定がハードコード -->
    <bean id="externalApiConfig" class="java.util.HashMap">
        <constructor-arg>
            <map>
                <entry key="salesforce.api.key" value="sf_api_key_12345"/>
                <entry key="salesforce.api.secret" value="sf_secret_67890"/>
                <entry key="slack.webhook.url" value="https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXX"/>
                <entry key="sendgrid.api.key" value="SG.xxxxxxxxxxxxxxxxx"/>
            </map>
        </constructor-arg>
    </bean>

    <!-- ISSUE: スケジューラー設定 -->
    <bean id="schedulerFactory" class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
        <property name="dataSource" ref="dataSource"/>
        <!-- ISSUE: 固定スレッド数 -->
        <property name="quartzProperties">
            <props>
                <prop key="org.quartz.threadPool.threadCount">50</prop>
                <!-- ISSUE: JDBCジョブストアの設定不備 -->
                <prop key="org.quartz.jobStore.class">org.quartz.impl.jdbcjobstore.JobStoreTX</prop>
            </props>
        </property>
    </bean>

    <!-- ISSUE: キャッシュマネージャーなし（パフォーマンス問題） -->

    <!-- ISSUE: バリデーターなし -->

    <!-- ISSUE: 監査設定なし -->

    <!-- ISSUE: 古いSpring AOP設定 -->
    <bean id="loggingAspect" class="com.example.crm.aspect.LoggingAspect">
        <!-- ISSUE: ログにセンシティブ情報を出力する設定 -->
        <property name="logSensitiveData" value="true"/>
        <property name="logLevel" value="DEBUG"/>
    </bean>

</beans>
