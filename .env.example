# IT Supervisor - 環境変数テンプレート
# 使用方法: このファイルを .env にコピーして値を設定してください
# $ cp .env.example .env

# ===========================================
# アプリケーション設定
# ===========================================
NODE_ENV=development
LOG_LEVEL=debug

# ===========================================
# データベース設定
# ===========================================
# PostgreSQL接続文字列（docker-compose使用時）
DATABASE_URL=postgresql://postgres:postgres@db:5432/it_supervisor

# または個別指定
DB_HOST=db
DB_PORT=5432
DB_NAME=it_supervisor
DB_USER=postgres
DB_PASSWORD=postgres

# ===========================================
# Redis設定
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ===========================================
# 静的解析ツール設定
# ===========================================
# ESLint
ESLINT_MAX_WARNINGS=0

# SonarQube（オプション）
SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=

# Snyk（オプション）
SNYK_TOKEN=

# ===========================================
# AWS設定（Phase 2: ECS環境用）
# ===========================================
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# S3バケット（レポート保存用）
# S3_BUCKET_NAME=it-supervisor-reports
# S3_REGION=ap-northeast-1

# ===========================================
# 認証・セキュリティ（将来のダッシュボード用）
# ===========================================
# JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# JWT_EXPIRATION=24h

# OAuth2（オプション）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ===========================================
# メール設定（レポート送信用、オプション）
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@it-supervisor.com

# ===========================================
# 監視・ログ設定
# ===========================================
# Sentry（エラートラッキング、オプション）
# SENTRY_DSN=

# CloudWatch（AWS環境用）
# CLOUDWATCH_LOG_GROUP=/ecs/it-supervisor
# CLOUDWATCH_LOG_STREAM=app

# ===========================================
# その他
# ===========================================
# タイムゾーン
TZ=Asia/Tokyo

# アプリケーションポート（将来のWeb UI用）
PORT=3000

# 最大並行分析ジョブ数
MAX_CONCURRENT_JOBS=3

# レポート保存期間（日数）
REPORT_RETENTION_DAYS=90

# 顧客リポジトリ保存期間（プロジェクト終了後、日数）
REPO_RETENTION_DAYS=30
