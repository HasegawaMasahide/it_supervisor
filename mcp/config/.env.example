# IT資産監査サービス - MCP環境変数設定例
# このファイルをコピーして .env として保存してください
# cp mcp/config/.env.example mcp/config/.env

# ===== 基本設定 =====

# ワークスペースパス（解析対象のリポジトリパス）
WORKSPACE_PATH=/path/to/customer/repository

# Gitリポジトリパス（複数の場合はコロン区切り）
GIT_REPO_PATH=/path/to/repo1:/path/to/repo2

# MCPサーバーの配置パス
MCP_SERVERS_PATH=/home/user/it_supervisor/mcp/servers

# ===== データベース設定 =====

# メトリクスデータベースパス（SQLite）
METRICS_DB_PATH=/home/user/it_supervisor/data/metrics.db

# ベクトルデータベースパス（改善提案の類似検索用）
VECTOR_DB_PATH=/home/user/it_supervisor/data/vector.db

# ===== GitHub設定 =====

# GitHub Personal Access Token
# スコープ: repo, read:org, read:user
# 取得方法: https://github.com/settings/tokens/new
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== セキュリティツール設定 =====

# Snyk API Token
# 取得方法: https://app.snyk.io/account
SNYK_TOKEN=

# Gitleaks有効化
ENABLE_GITLEAKS=true

# Snyk有効化
ENABLE_SNYK=false

# OWASP Dependency-Check有効化
ENABLE_OWASP_DEPENDENCY_CHECK=true

# ===== 静的解析設定 =====

# PHP解析有効化
ENABLE_PHP_ANALYSIS=true

# C#解析有効化
ENABLE_CSHARP_ANALYSIS=false

# PHPStanレベル（0-9）
PHPSTAN_LEVEL=5

# Psalm設定ファイルパス
PSALM_CONFIG_PATH=

# ===== AI/LLM設定 =====

# OpenAI API Key（ベクトル検索のEmbedding用）
OPENAI_API_KEY=

# Embeddingモデル
EMBEDDING_MODEL=text-embedding-3-small

# ===== パフォーマンス設定 =====

# データベースクエリのタイムアウト（ミリ秒）
QUERY_TIMEOUT=30000

# 最大行数制限
ROW_LIMIT=1000

# ===== ログ設定 =====

# ログレベル（debug, info, warn, error）
LOG_LEVEL=info

# ログ出力先
LOG_PATH=/home/user/it_supervisor/logs/mcp.log

# ===== Docker設定 =====

# Dockerイメージのプレフィックス
DOCKER_IMAGE_PREFIX=it-supervisor

# Dockerイメージのタグ
DOCKER_IMAGE_TAG=latest

# ===== セキュリティ設定 =====

# 読み取り専用モード（データベース破壊を防ぐ）
READ_ONLY=false

# 許可するファイル拡張子（カンマ区切り）
ALLOWED_EXTENSIONS=.js,.ts,.jsx,.tsx,.php,.cs,.py,.go,.rb,.java,.kt

# 除外するディレクトリ（カンマ区切り）
EXCLUDED_DIRS=node_modules,vendor,.git,.vscode,dist,build

# ===== プロジェクト管理 =====

# 現在のプロジェクトID
CURRENT_PROJECT_ID=

# プロジェクトデータディレクトリ
PROJECT_DATA_DIR=/home/user/it_supervisor/projects

# ===== その他 =====

# タイムゾーン
TZ=Asia/Tokyo

# デバッグモード
DEBUG=false

# ドライランモード（実際の変更を行わない）
DRY_RUN=false
